[package]
name        = "delta"
version     = "0.18.2"
description = "Syntax-highlighting pager for git and diff output"
license     = "MIT"
maintainer  = "mycel-linux"
arch        = "x86_64"

[source]
type     = "github-release"
repo     = "dandavison/delta"
tag      = "0.18.2"
asset    = "delta-0.18.2-x86_64-unknown-linux-gnu.tar.gz"

[install]
binaries = [
  { from = "delta-0.18.2-x86_64-unknown-linux-gnu/delta", to = "delta" }
]
