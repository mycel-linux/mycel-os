[package]
name        = "eza"
version     = "0.20.2"
description = "Modern replacement for ls with colour and Git integration"
license     = "MIT"
maintainer  = "mycel-linux"
arch        = "x86_64"

[source]
type     = "github-release"
repo     = "eza-community/eza"
tag      = "v0.20.2"
asset    = "eza_x86_64-unknown-linux-gnu.tar.gz"

[install]
binaries = [
  { from = "eza", to = "eza" }
]
