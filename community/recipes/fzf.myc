[package]
name        = "fzf"
version     = "0.56.3"
description = "Command-line fuzzy finder"
license     = "MIT"
maintainer  = "mycel-linux"
arch        = "x86_64"

[source]
type     = "github-release"
repo     = "junegunn/fzf"
tag      = "v0.56.3"
asset    = "fzf-0.56.3-linux_amd64.tar.gz"

[install]
binaries = [
  { from = "fzf", to = "fzf" }
]
