[package]
name        = "slurp"
version     = "1.5.0"
description = "Select a region in a Wayland compositor for use with grim"
license     = "MIT"
maintainer  = "mycel-linux"
arch        = "x86_64"

[source]
type = "github-release"
repo = "emersion/slurp"
tag  = "v1.5.0"
asset = "slurp-1.5.0.tar.gz"

[build]
system   = "meson"
commands = [
  "meson setup build --prefix=/usr",
  "ninja -C build",
  "ninja -C build install",
]

[install]
binaries = [
  { from = "build/slurp", to = "slurp" }
]
