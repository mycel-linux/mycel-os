[package]
name        = "starship"
version     = "1.21.1"
description = "Minimal, fast, and customisable cross-shell prompt"
license     = "ISC"
maintainer  = "mycel-linux"
arch        = "x86_64"

[source]
type     = "github-release"
repo     = "starship/starship"
tag      = "v1.21.1"
asset    = "starship-x86_64-unknown-linux-gnu.tar.gz"

[install]
binaries = [
  { from = "starship", to = "starship" }
]
