[package]
name        = "wlogout"
version     = "1.2.2"
description = "Wayland logout menu"
license     = "MIT"
maintainer  = "mycel-linux"
arch        = "x86_64"

[source]
type = "github-release"
repo = "ArtsyMacaw/wlogout"
tag  = "1.2.2"
asset = "wlogout-1.2.2.tar.gz"

[build]
system   = "meson"
commands = [
  "meson setup build --prefix=/usr",
  "ninja -C build",
  "ninja -C build install",
]

[install]
binaries = [
  { from = "build/wlogout", to = "wlogout" }
]
