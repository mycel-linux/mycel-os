      "shell": "mycel active --gen 2>/dev/null || echo 'unknown'"
    },
    {
      "type": "custom",
      "format": ""
    },
    {
      "type": "colors",
      "paddingLeft": 1,
      "symbol": "circle"
    }
  ]
